<style>
  abbr.badge { background-color: #6b7280 !important; color: white !important; }
  abbr.badge-MLSys { background-color: #14b8a6 !important; }
  abbr.badge-ICML { background-color: #2563eb !important; }
  abbr.badge-ICASSP { background-color: #ea580c !important; }
  abbr.badge-ISCA { background-color: #7c3aed !important; }
  abbr.badge-NeurIPS { background-color: #dc2626 !important; }
  abbr.badge-arXiv,
  abbr.badge-Arxiv,
  abbr.badge-arxiv { background-color: #b31b1b !important; }

  h2 > a[href="/news/"],
  h2 > a[href="/publications/"] {
    text-transform: capitalize;
  }
</style>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('abbr.badge').forEach(function (el) {
      var venue = el.textContent.trim();
      if (venue) el.classList.add('badge-' + venue);
    });
  });
</script>
